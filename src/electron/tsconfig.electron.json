{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "declaration": false,
    "rootDir": "../..",
    "skipLibCheck": true
  },
  "include": [
    "main.ts",
    "ipc-contract.ts",
    "ipc-payloads.ts",
    "ipc-handlers.ts",
    "profile-state.ts",
    "registry-service.ts",
    "launch.ts",
    "dev.ts"
  ],
  "exclude": ["public"]
}
